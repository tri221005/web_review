@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng Nhập";
}

<style>
    .auth-fullscreen-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: url('/images/vietnam_intro.png') center/cover no-repeat;
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .auth-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    
    .glass-card {
        background: rgba(15, 15, 15, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
        padding: 3.5rem;
        width: 100%;
        max-width: 480px;
        position: relative;
        z-index: 1051;
        color: #fff;
        animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        transform: translateY(40px);
        opacity: 0;
    }

    @@keyframes slideUpFade {
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .glass-card h3 {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-weight: 800;
        letter-spacing: 3px;
        color: #d4af37;
        text-align: center;
        margin-bottom: 2.5rem;
        text-transform: uppercase;
    }

    .form-floating .form-control {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #fff !important;
        border-radius: 12px;
    }
    
    .form-floating .form-control:focus {
        background: rgba(255, 255, 255, 0.1) !important;
        border-color: #d4af37;
        box-shadow: 0 0 0 0.25rem rgba(212, 175, 55, 0.2);
    }

    .form-floating label {
        color: #999;
    }

    .form-floating .form-control:focus ~ label,
    .form-floating .form-control:not(:placeholder-shown) ~ label {
        color: #d4af37;
        transform: scale(0.85) translateY(-0.75rem) translateX(0.15rem);
    }

    .btn-gold {
        background: linear-gradient(135deg, #d4af37 0%, #aa8c2c 100%);
        color: #000;
        font-weight: 700;
        border: none;
        padding: 1rem;
        border-radius: 50px;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

    .btn-gold:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 25px rgba(212, 175, 55, 0.4);
        color: #000;
    }

    .auth-link {
        color: #bbb;
        text-decoration: none;
        transition: color 0.3s ease;
        font-size: 0.95rem;
    }

    .auth-link:hover {
        color: #d4af37;
    }

    .back-btn {
        position: absolute;
        top: 30px;
        left: 40px;
        color: #fff;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1rem;
        font-weight: 500;
        opacity: 0.8;
        transition: all 0.3s ease;
        z-index: 1052;
    }

    .back-btn:hover {
        opacity: 1;
        color: #d4af37;
        transform: translateX(-5px);
    }

    .custom-checkbox .form-check-input {
        background-color: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.3);
    }
    
    .custom-checkbox .form-check-input:checked {
        background-color: #d4af37;
        border-color: #d4af37;
    }
</style>

<div class="auth-fullscreen-bg">
    <div class="auth-overlay"></div>
    <a href="/" class="back-btn">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Trở Về
    </a>

    <div class="glass-card">
        <h3>@ViewData["Title"]</h3>
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
            
            <div class="form-floating mb-4">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Tài khoản hoặc Email" type="text" />
                <label asp-for="Input.Email">Tài khoản hoặc Email</label>
                <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
            </div>
            
            <div class="form-floating mb-4">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" type="password" />
                <label asp-for="Input.Password">Mật khẩu</label>
                <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
            </div>
            
            <div class="form-check custom-checkbox mb-4">
                <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMeCheck" />
                <label class="form-check-label text-light" for="rememberMeCheck" style="cursor: pointer;">
                    Nhớ mật khẩu
                </label>
            </div>
            
            <button id="login-submit" type="submit" class="w-100 btn btn-gold mb-3">ĐĂNG NHẬP</button>
            

            
            <div class="d-flex justify-content-between text-center mt-3">
                <a class="auth-link" id="forgot-password" asp-page="./ForgotPassword">Quên mật khẩu?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Tạo tài khoản</a>
            </div>
        </form>
        
        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="text-center mb-3">
                <span class="text-light small">HOẶC ĐĂNG NHẬP BẰNG</span>
            </div>
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                <div class="d-grid gap-2 mb-4">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn btn-outline-light d-flex align-items-center justify-content-center gap-2" name="provider" value="@provider.Name" title="Đăng nhập bằng tài khoản @provider.DisplayName của bạn">
                            @if(provider.Name == "Google") {
                                <svg width="20" height="20" viewBox="0 0 48 48">
                                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                    <path fill="none" d="M0 0h48v48H0z"/>
                                </svg>
                                <span>Đăng nhập với @provider.DisplayName</span>
                            } else {
                                <span>@provider.DisplayName</span>
                            }
                        </button>
                    }
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
