@model IEnumerable<page.Models.TravelStory>
@{
    ViewData["Title"] = "Câu Chuyện Du Lịch";
    Layout = "_Layout";
    var userId = User.Identity?.IsAuthenticated == true ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : null;
}

<div class="section pt-4" style="max-width: 900px; margin: 0 auto; padding: 0 15px 5rem;">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="text-white fw-bold mb-0"><i class="bi bi-journal-richtext text-warning me-2"></i>Câu Chuyện Du Lịch</h1>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="Create" class="btn rounded-pill" style="background: var(--gold); color: #000;">
                <i class="bi bi-pencil me-1"></i> Viết câu chuyện
            </a>
        }
    </div>

    @foreach (var story in Model)
    {
        <div class="card border-0 mb-4 overflow-hidden" style="background: rgba(20,20,25,0.8); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05) !important;">
            <div class="row g-0">
                @if (!string.IsNullOrEmpty(story.ImageUrl))
                {
                    <div class="col-md-4">
                        <img src="@story.ImageUrl" alt="@story.Title" style="width:100%; height:100%; min-height:180px; object-fit:cover;">
                    </div>
                }
                <div class="@(string.IsNullOrEmpty(story.ImageUrl) ? "col-12" : "col-md-8")">
                    <div class="card-body p-4">
                        <div class="small text-muted mb-1">
                            <a asp-controller="Destinations" asp-action="Details" asp-route-id="@story.DestinationId" class="text-danger text-decoration-none">
                                @(story.Destination?.Name)
                            </a>
                            · @(story.User?.FullName ?? story.User?.UserName) · @story.CreatedAt.ToString("dd/MM/yyyy")
                        </div>
                        <h5 class="text-white fw-bold">@story.Title</h5>
                        <p class="text-muted mb-3" style="white-space: pre-wrap;">@story.Content</p>
                        <div class="d-flex gap-2 align-items-center">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-action="Upvote" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@story.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning rounded-pill">
                                        <i class="bi bi-hand-thumbs-up"></i> @story.UpvoteCount
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small"><i class="bi bi-hand-thumbs-up"></i> @story.UpvoteCount</span>
                            }
                            <button class="btn btn-sm btn-outline-light rounded-pill toggle-comments" data-story-id="@story.Id">
                                <i class="bi bi-chat-dots"></i> Bình luận (@((story.Comments?.Count ?? 0)))
                            </button>
                        </div>

                        <div class="comments-section mt-3 d-none" id="comments-@story.Id">
                            <hr style="border-color: rgba(255,255,255,0.1);">
                            @if (story.Comments != null && story.Comments.Any())
                            {
                                foreach (var comment in story.Comments.OrderBy(c => c.CreatedAt))
                                {
                                    <div class="d-flex gap-2 mb-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center bg-secondary text-white fw-bold flex-shrink-0" style="width: 30px; height: 30px; font-size: 0.75rem;">
                                            @((comment.User?.FullName ?? comment.User?.UserName ?? "?")[0])
                                        </div>
                                        <div class="flex-grow-1 p-2 rounded-3" style="background: rgba(0,0,0,0.3);">
                                            <div class="small fw-bold text-white">@(comment.User?.FullName ?? comment.User?.UserName ?? "Ẩn danh")</div>
                                            <div class="small" style="color: #ccc;">@comment.Content</div>
                                            <div class="small text-muted" style="font-size: 0.7rem;">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                }
                            }
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-action="AddComment" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="storyId" value="@story.Id" />
                                    <div class="input-group">
                                        <input type="text" name="content" class="form-control form-control-sm" placeholder="Viết bình luận..." required style="background: rgba(0,0,0,0.5); color: white; border: none;">
                                        <button type="submit" class="btn btn-sm btn-warning">Gửi</button>
                                    </div>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <p class="text-center text-muted py-5">Chưa có câu chuyện nào. Hãy là người đầu tiên chia sẻ!</p>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.toggle-comments').forEach(btn => {
            btn.addEventListener('click', function() {
                const id = this.getAttribute('data-story-id');
                const section = document.getElementById('comments-' + id);
                section.classList.toggle('d-none');
            });
        });
    </script>
}
