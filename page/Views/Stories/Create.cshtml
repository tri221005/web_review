@model page.Models.TravelStory
@{
    ViewData["Title"] = "Viết Câu Chuyện";
    Layout = "_Layout";
    var destinations = ViewBag.Destinations as List<page.Models.Destination> ?? new List<page.Models.Destination>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/stories.css" asp-append-version="true" />
}

<div class="section pt-4 story-create-section">
    <h1 class="text-white fw-bold mb-4 text-center">Viết Câu Chuyện Du Lịch</h1>
    <div class="card border-0 p-4 p-md-5 story-form-card">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger story-alert-danger"></div>
            }

            <div class="mb-4">
                <label class="form-label fw-bold small text-uppercase story-form-label">Điểm đến</label>
                <select asp-for="DestinationId" class="form-select form-select-lg shadow-sm custom-dark-input">
                    <option value="0" class="custom-dark-option">-- Chọn điểm đến --</option>
                    @foreach (var d in destinations)
                    {
                        <option value="@d.Id" class="custom-dark-option">@d.Name</option>
                    }
                </select>
            </div>
            <div class="mb-4">
                <label asp-for="Title" class="form-label fw-bold small text-uppercase story-form-label">Tiêu đề</label>
                <input asp-for="Title" class="form-control form-control-lg shadow-sm custom-dark-input" placeholder="Nhập tiêu đề câu chuyện..." />
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold small text-uppercase story-form-label">Ảnh đại diện (tải lên)</label>
                <input type="file" name="imageFile" accept="image/*" class="form-control form-control-lg shadow-sm custom-file-input">
            </div>
            <div class="mb-4">
                <label asp-for="ImageUrl" class="form-label fw-bold small text-uppercase story-form-label">Hoặc URL ảnh từ web</label>
                <input asp-for="ImageUrl" class="form-control form-control-lg shadow-sm custom-dark-input" placeholder="https://..." />
            </div>
            <div class="mb-5">
                <label asp-for="Content" class="form-label fw-bold small text-uppercase story-form-label">Nội dung</label>
                <textarea asp-for="Content" rows="8" class="form-control form-control-lg shadow-sm custom-dark-input" placeholder="Kể lại trải nghiệm của bạn..."></textarea>
            </div>
            <button type="submit" class="btn w-100 rounded-pill py-2 fw-bold btn-gold">Đăng câu chuyện</button>
        </form>
    </div>
</div>
