@{
    ViewData["Title"] = "Lộ Trình Của Tôi";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2><i class="fas fa-route"></i> Lộ Trình Du Lịch Của Tôi</h2>
                <a href="@Url.Action("GenerateItinerary", "AI")" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Tạo Lộ Trình Mới
                </a>
            </div>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <i class="fas fa-map-marked-alt fa-5x text-muted mb-3"></i>
            <h4 class="text-muted">Bạn chưa có lộ trình nào</h4>
            <p class="text-muted">Hãy tạo lộ trình đầu tiên với AI của chúng tôi!</p>
            <a href="@Url.Action("GenerateItinerary", "AI")" class="btn btn-primary btn-lg">
                <i class="fas fa-magic"></i> Tạo Ngay
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var itinerary in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm hover-shadow">
                        <div class="card-header bg-gradient text-white" 
                             style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">@itinerary.Title</h5>
                                @if (itinerary.IsAIGenerated)
                                {
                                    <span class="badge bg-warning">
                                        <i class="fas fa-robot"></i> AI
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-2">@itinerary.Description</p>
                            
                            <div class="mb-3">
                                <span class="badge bg-info me-1">
                                    <i class="fas fa-calendar"></i> @itinerary.DurationDays ngày
                                </span>
                                <span class="badge bg-success me-1">
                                    <i class="fas fa-wallet"></i> @itinerary.EstimatedBudget.ToString("N0") VNĐ
                                </span>
                                <span class="badge bg-secondary">
                                    <i class="fas fa-signal"></i> @itinerary.DifficultyLevel
                                </span>
                            </div>

                            <div class="small text-muted">
                                <div class="mb-1">
                                    <i class="fas fa-play-circle"></i> 
                                    Bắt đầu: @itinerary.StartDate.ToString("dd/MM/yyyy")
                                </div>
                                <div>
                                    <i class="fas fa-stop-circle"></i> 
                                    Kết thúc: @itinerary.EndDate.ToString("dd/MM/yyyy")
                                </div>
                            </div>

                            <hr>

                            <h6 class="mb-2"><i class="fas fa-list"></i> Các ngày:</h6>
                            <ul class="list-unstyled mb-3">
                                @foreach (var day in itinerary.Days.Take(3))
                                {
                                    <li class="mb-1">
                                        <span class="badge bg-light text-dark border">
                                            Ngày @day.DayNumber: @day.Title
                                        </span>
                                    </li>
                                }
                                @if (itinerary.Days.Count > 3)
                                {
                                    <li class="text-muted fst-italic">
                                        + @(itinerary.Days.Count - 3) ngày khác...
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="card-footer bg-white">
                            <div class="d-grid gap-2">
                                <a href="@Url.Action("ViewItinerary", "AI", new { id = itinerary.Id })" 
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-eye"></i> Xem Chi Tiết
                                </a>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteItinerary(@itinerary.Id)">
                                    <i class="fas fa-trash"></i> Xóa
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    async function deleteItinerary(id) {
        if (!confirm('Bạn có chắc muốn xóa lộ trình này?')) return;

        try {
            // TODO: Implement delete API
            alert('Chức năng xóa đang được phát triển');
        } catch (error) {
            alert('Lỗi: ' + error.message);
        }
    }
</script>
}

@section Styles {
<style>
    .hover-shadow:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        transform: translateY(-2px);
        transition: all 0.3s ease;
    }

    .card {
        transition: all 0.3s ease;
    }
</style>
}
