@model page.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Hồ Sơ Của Tôi";
    Layout = "_Layout";
    var notifications = ViewBag.Notifications as List<page.Models.UserNotification> ?? new();
    var unreadCount = (int)(ViewBag.UnreadCount ?? 0);
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="container" style="max-width: 1200px;">
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-4 rounded-3" role="alert" style="background: rgba(46, 125, 50, 0.2); border: 1px solid #2E7D32; color: #fff;">
            <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-4 rounded-3" role="alert" style="background: rgba(198, 40, 40, 0.2); border: 1px solid #C62828; color: #fff;">
            <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- PROFILE HEADER -->
    <div class="profile-header-wrapper">
        <div class="profile-cover"></div>
        <div class="profile-avatar-container">
            <div class="profile-avatar-lg">
                @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="Avatar của @(Model.FullName ?? Model.UserName)">
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 fs-1 text-white fw-bold">
                        @(Model.FullName?.FirstOrDefault() ?? Model.UserName.FirstOrDefault())
                    </div>
                }
                
                <form id="avatarForm" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="fullName" value="@Model.FullName" />
                    <label for="avatarUpload" class="profile-avatar-upload" aria-label="Thay đổi ảnh đại diện" title="Thay đổi ảnh đại diện">
                        <i class="bi bi-camera-fill"></i>
                    </label>
                    <input type="file" id="avatarUpload" name="avatarFile" accept="image/*" class="d-none" onchange="document.getElementById('avatarForm').submit()">
                </form>
            </div>
            <div class="profile-info">
                <h1 class="profile-name">@(Model.FullName ?? Model.UserName)</h1>
                <p class="profile-username">@@@Model.UserName</p>
                @if (Model.HasExplorerBadge)
                {
                    <span class="badge rounded-pill mt-2" style="background: rgba(212, 175, 55, 0.2); color: var(--gold); border: 1px solid var(--gold);">
                        <i class="bi bi-trophy-fill me-1"></i> Nhà Thám Hiểm Việt Nam
                    </span>
                }
            </div>
            <div class="ms-auto pb-3 d-none d-md-block">
                <button class="btn btn-outline-light rounded-pill px-4" onclick="switchTab('settings')">
                    <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa hồ sơ
                </button>
            </div>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="profile-tabs" role="tablist">
        <button class="profile-tab active" id="tab-overview" role="tab" aria-selected="true" aria-controls="content-overview" onclick="switchTab('overview')">Tổng quan</button>
        <button class="profile-tab" id="tab-stories" role="tab" aria-selected="false" aria-controls="content-stories" onclick="switchTab('stories')">Câu chuyện (@Model.TotalStories)</button>
        <button class="profile-tab" id="tab-saved" role="tab" aria-selected="false" aria-controls="content-saved" onclick="switchTab('saved')">Đã lưu (@Model.TotalSaved)</button>
        <button class="profile-tab" id="tab-notifications" role="tab" aria-selected="false" aria-controls="content-notifications" onclick="switchTab('notifications')">
            Thông báo 
            @if(unreadCount > 0) { <span class="badge bg-danger ms-1">@unreadCount</span> }
        </button>
        <button class="profile-tab d-md-none" id="tab-settings" role="tab" aria-selected="false" aria-controls="content-settings" onclick="switchTab('settings')">Cài đặt</button>
    </div>

    <!-- TAB CONTENTS -->
    <div class="tab-content pb-5">
        
        <!-- 1. OVERVIEW TAB -->
        <div id="content-overview" class="tab-pane active">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="glass-card p-4 h-100" style="background: rgba(20,20,25,0.4); border-radius: 20px;">
                        <h4 class="fw-bold mb-4"><i class="bi bi-award text-warning me-2"></i>Thành tích & Huy hiệu</h4>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="profile-stat-card">
                                    <div class="stat-number">@Model.TotalReviews</div>
                                    <div class="stat-label">Đánh giá</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="profile-stat-card">
                                    <div class="stat-number">@Model.TotalStories</div>
                                    <div class="stat-label">Câu chuyện</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="profile-stat-card">
                                    <div class="stat-number">@Model.TotalSaved</div>
                                    <div class="stat-label">Đã lưu</div>
                                </div>
                            </div>
                        </div>

                        <h5 class="fw-bold mt-5 mb-3 text-light">Bộ sưu tập tem vùng miền</h5>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var stamp in Model.Stamps)
                            {
                                <div class="text-center p-3 rounded-3" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05); min-width: 90px; transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                                    <i class="bi @stamp.Icon fs-1 @(stamp.IsEarned ? "text-warning" : "text-light opacity-25")"></i>
                                    <div class="small mt-2 @(stamp.IsEarned ? "text-light fw-bold" : "text-muted")" style="font-size: 0.8rem;">@stamp.Region</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="glass-card p-4 h-100" style="background: rgba(20,20,25,0.4); border-radius: 20px;">
                        <h5 class="fw-bold mb-4"><i class="bi bi-clock-history text-danger me-2"></i>Hoạt động gần đây</h5>
                        
                        @if (!Model.RecentStories.Any() && !Model.SavedDestinations.Any())
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-wind fs-1 mb-3 d-block opacity-50"></i>
                                <p>Chưa có hoạt động nào.</p>
                                <a href="/Destinations" class="btn btn-outline-warning btn-sm rounded-pill mt-2">Khám phá ngay</a>
                            </div>
                        }
                        else
                        {
                            <ul class="list-unstyled">
                                @foreach (var story in Model.RecentStories.Take(3))
                                {
                                    <li class="mb-3 pb-3 border-bottom border-secondary border-opacity-25">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2">
                                                <i class="bi bi-journal-text"></i>
                                            </div>
                                            <div>
                                                <p class="mb-1 text-light">Bạn đã viết <strong>@story.Title</strong></p>
                                                <small class="text-muted">@story.CreatedAt.ToString("dd/MM/yyyy")</small>
                                            </div>
                                        </div>
                                    </li>
                                }
                                @foreach (var dest in Model.SavedDestinations.Take(2))
                                {
                                    <li class="mb-3 pb-3 border-bottom border-secondary border-opacity-25">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-2">
                                                <i class="bi bi-heart-fill"></i>
                                            </div>
                                            <div>
                                                <p class="mb-1 text-light">Bạn đã lưu <strong>@dest.Destination?.Name</strong></p>
                                                <small class="text-muted">Gần đây</small>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. STORIES TAB -->
        <div id="content-stories" class="tab-pane" style="display: none;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold m-0">Nhật ký hành trình</h4>
                <a asp-controller="Stories" asp-action="Create" class="btn btn-warning rounded-pill fw-bold text-dark px-4">
                    <i class="bi bi-pencil-square me-2"></i> Viết bài mới
                </a>
            </div>

            @if (!Model.RecentStories.Any())
            {
                <div class="glass-card text-center py-5" style="border-radius: 20px; border: 2px dashed rgba(255,255,255,0.1);">
                    <i class="bi bi-journal-x fs-1 text-muted mb-3 d-block"></i>
                    <h5 class="text-light">Bạn chưa viết câu chuyện nào</h5>
                    <p class="text-muted mb-4">Hãy chia sẻ những trải nghiệm tuyệt vời của bạn với cộng đồng.</p>
                    <a asp-controller="Stories" asp-action="Create" class="btn btn-outline-light rounded-pill px-4">Bắt đầu viết</a>
                </div>
            }
            else
            {
                <div class="glass-card p-0 overflow-hidden" style="border-radius: 20px; background: rgba(20,20,25,0.4);">
                    @foreach (var story in Model.RecentStories)
                    {
                        <div class="d-flex justify-content-between align-items-center p-4 border-bottom border-secondary border-opacity-25 story-list-item">
                            <div class="d-flex gap-4 align-items-center">
                                <div class="bg-dark rounded-3 d-flex align-items-center justify-content-center text-muted" style="width: 80px; height: 80px; border: 1px solid rgba(255,255,255,0.1);">
                                    <i class="bi bi-image fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-white mb-2">@story.Title</h5>
                                    <div class="d-flex gap-3 small text-muted">
                                        <span><i class="bi bi-geo-alt-fill text-danger me-1"></i> @(story.Destination?.Name ?? "Điểm đến")</span>
                                        <span><i class="bi bi-calendar-event me-1"></i> @story.CreatedAt.ToString("dd/MM/yyyy")</span>
                                        <span class="text-warning"><i class="bi bi-hand-thumbs-up-fill me-1"></i> @story.UpvoteCount lượt thích</span>
                                    </div>
                                </div>
                            </div>
                            <a asp-controller="Stories" asp-action="Details" asp-route-id="@story.Id" class="btn btn-sm btn-outline-light rounded-pill px-3">Xem chi tiết</a>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- 3. SAVED TAB -->
        <div id="content-saved" class="tab-pane" style="display: none;">
            <h4 class="fw-bold mb-4">Điểm đến đã lưu</h4>
            
            @if (!Model.SavedDestinations.Any())
            {
                <div class="glass-card text-center py-5" style="border-radius: 20px; border: 2px dashed rgba(255,255,255,0.1);">
                    <i class="bi bi-heart fs-1 text-muted mb-3 d-block"></i>
                    <h5 class="text-light">Danh sách trống</h5>
                    <p class="text-muted mb-4">Bạn chưa lưu điểm đến nào vào danh sách yêu thích.</p>
                    <a href="/Destinations" class="btn btn-outline-light rounded-pill px-4">Khám phá ngay</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var item in Model.SavedDestinations)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 bg-transparent border-0 dest-card-hover">
                                <div class="position-relative rounded-4 overflow-hidden" style="aspect-ratio: 4/3;">
                                    <img src="@(string.IsNullOrEmpty(item.Destination?.ImageUrl) ? "https://images.unsplash.com/photo-1559592413-7cec4d0cae2b" : item.Destination.ImageUrl)" 
                                         class="w-100 h-100 object-fit-cover" alt="@item.Destination?.Name">
                                    <div class="position-absolute top-0 end-0 p-3">
                                        <form asp-action="UnsaveDestination" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="destinationId" value="@item.DestinationId" />
                                            <button type="submit" class="btn btn-danger rounded-circle p-2 lh-1 shadow" title="Bỏ lưu" aria-label="Bỏ lưu khỏi danh sách yêu thích">
                                                <i class="bi bi-heart-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 w-100 p-3" style="background: linear-gradient(transparent, rgba(0,0,0,0.9));">
                                        <h5 class="text-white fw-bold mb-1">@item.Destination?.Name</h5>
                                        <div class="text-light small opacity-75"><i class="bi bi-geo-alt me-1"></i>@item.Destination?.Location</div>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <a asp-controller="Destinations" asp-action="Details" asp-route-id="@item.DestinationId" class="btn btn-outline-light w-100 rounded-pill">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- 4. NOTIFICATIONS TAB -->
        <div id="content-notifications" class="tab-pane" style="display: none;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold m-0">Thông báo của bạn</h4>
                @if (unreadCount > 0)
                {
                    <form asp-action="MarkAllNotificationsRead" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-warning btn-sm rounded-pill px-3">
                            <i class="bi bi-check2-all me-1"></i> Đánh dấu đã đọc tất cả
                        </button>
                    </form>
                }
            </div>

            @if (!notifications.Any())
            {
                <div class="glass-card text-center py-5" style="border-radius: 20px; border: 2px dashed rgba(255,255,255,0.1);">
                    <i class="bi bi-bell-slash fs-1 text-muted mb-3 d-block"></i>
                    <h5 class="text-light">Không có thông báo mới</h5>
                </div>
            }
            else
            {
                <div class="glass-card p-0 overflow-hidden" style="border-radius: 20px; background: rgba(20,20,25,0.4);">
                    <ul class="list-unstyled m-0" role="list">
                        @foreach (var n in notifications)
                        {
                            <li class="p-4 border-bottom border-secondary border-opacity-25 @(n.IsRead ? "" : "bg-warning bg-opacity-10")">
                                <div class="d-flex gap-3">
                                    <div class="text-warning fs-3 mt-n1">
                                        <i class="bi @(n.IsRead ? "bi-bell" : "bi-bell-fill")"></i>
                                    </div>
                                    <div>
                                        <h6 class="text-white fw-bold mb-1">@n.Title</h6>
                                        @if (!string.IsNullOrEmpty(n.Message))
                                        {
                                            <p class="text-light opacity-75 mb-2">@n.Message</p>
                                        }
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> @n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>

        <!-- 5. SETTINGS TAB -->
        <div id="content-settings" class="tab-pane" style="display: none;">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="glass-card p-4" style="background: rgba(20,20,25,0.4); border-radius: 20px;">
                        <h4 class="fw-bold mb-4"><i class="bi bi-person-lines-fill text-warning me-2"></i>Chỉnh sửa thông tin</h4>
                        
                        <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            
                            <div class="mb-4">
                                <label class="form-label text-light opacity-75 small text-uppercase fw-bold">Họ và tên hiển thị</label>
                                <input type="text" name="fullName" value="@Model.FullName" class="form-control edit-form-control" placeholder="Nhập họ tên của bạn">
                            </div>

                            <div class="mb-4">
                                <label class="form-label text-light opacity-75 small text-uppercase fw-bold">Tên đăng nhập (@("@username")</label>
                                <input type="text" value="@Model.UserName" class="form-control edit-form-control" disabled readonly style="background: rgba(0,0,0,0.1); cursor: not-allowed;">
                                <div class="form-text text-muted mt-1">Tên đăng nhập không thể thay đổi.</div>
                            </div>
                            
                            <hr class="border-secondary border-opacity-25 my-4">

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold text-dark">
                                    <i class="bi bi-save me-2"></i> Lưu thay đổi
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="glass-card p-4 h-100" style="background: rgba(20,20,25,0.4); border-radius: 20px;">
                        <h4 class="fw-bold mb-4"><i class="bi bi-shield-lock text-danger me-2"></i>Bảo mật & Tài khoản</h4>
                        
                        <div class="d-grid gap-3">
                            <a href="/Identity/Account/Manage/ChangePassword" class="btn btn-outline-light text-start p-3 rounded-3 d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="fw-bold mb-1">Đổi mật khẩu</div>
                                    <div class="small text-muted">Cập nhật mật khẩu để bảo vệ tài khoản</div>
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                            
                            <a href="/Identity/Account/Manage/ExternalLogins" class="btn btn-outline-light text-start p-3 rounded-3 d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="fw-bold mb-1">Tài khoản liên kết</div>
                                    <div class="small text-muted">Quản lý đăng nhập bằng Google, Facebook...</div>
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const hash = window.location.hash.replace('#', '');
        if (hash && document.getElementById('tab-' + hash)) {
            switchTab(hash, false);
        }
    });

    function switchTab(tabId, updateHash = true) {
        // Reset active state for tabs
        document.querySelectorAll('.profile-tab').forEach(el => {
            el.classList.remove('active');
            el.setAttribute('aria-selected', 'false');
        });
        
        const activeTab = document.getElementById('tab-' + tabId);
        if (activeTab) {
            activeTab.classList.add('active');
            activeTab.setAttribute('aria-selected', 'true');
        }

        // Hide all content panes
        document.querySelectorAll('.tab-pane').forEach(el => el.style.display = 'none');
        
        // Show selected pane
        const contentPane = document.getElementById('content-' + tabId);
        if (contentPane) {
            contentPane.style.display = 'block';
        }

        if (updateHash) {
            history.pushState(null, null, '#' + tabId);
        }
    }
</script>
