@model IEnumerable<page.Models.Destination>
@{
    ViewData["Title"] = "Địa Điểm Du Lịch";
    Layout = "_Layout";
    var savedIds = ViewBag.SavedDestinationIds as List<int> ?? new List<int>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/destinations.css" asp-append-version="true" />
}

<!-- Hero Section for Destinations -->
<div class="hero destinations-hero">
    <div class="hero-bg destinations-hero-bg"></div>
    <div class="hero-overlay destinations-hero-overlay"></div>
    <div class="hero-pattern"></div>
    <div class="hero-content text-center reveal">
        <div class="hero-badge"><i class="bi bi-compass"></i> Khám Phá Việt Nam</div>
        <h1 class="destinations-hero-title">Các <span>Địa Điểm</span> Tuyệt Vời</h1>
        <p class="destinations-hero-desc">Tìm kiếm và lựa chọn những điểm đến lý tưởng nhất cho hành trình của bạn.</p>
    </div>
</div>

<div class="section pt-5 destinations-section">
    <!-- Filter Section with Glassmorphism -->
    <div class="card border-0 mb-5 reveal-scale filter-card">
        <div class="card-body p-4">
            <form id="filter-form" asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold filter-label"><i class="bi bi-search text-danger me-1"></i> Tìm kiếm</label>
                    <input type="text" name="searchString" value="@Context.Request.Query["searchString"]" class="form-control form-control-lg border-0 shadow-sm filter-input" placeholder="Tên hoặc mô tả...">
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold filter-label"><i class="bi bi-geo-alt-fill text-danger me-1"></i> Khu vực</label>
                    <select name="location" class="form-select form-select-lg border-0 shadow-sm custom-dark-select filter-select" aria-label="Lọc theo khu vực">
                        <option value="">Tất cả khu vực</option>
                        @if(ViewBag.Locations != null)
                        {
                            foreach (var loc in ViewBag.Locations)
                            {
                                if(!string.IsNullOrEmpty(loc))
                                {
                                    if(Context.Request.Query["location"] == loc)
                                    {
                                        <option value="@loc" selected>@loc</option>
                                    }
                                    else
                                    {
                                        <option value="@loc">@loc</option>
                                    }
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold filter-label"><i class="bi bi-tags-fill text-danger me-1"></i> Loại hình</label>
                    <select name="type" class="form-select form-select-lg border-0 shadow-sm custom-dark-select filter-select" aria-label="Lọc theo loại hình">
                        <option value="">Tất cả loại hình</option>
                        @if(ViewBag.Types != null)
                        {
                            foreach (var type in ViewBag.Types)
                            {
                                if(!string.IsNullOrEmpty(type))
                                {
                                    if(Context.Request.Query["type"] == type)
                                    {
                                        <option value="@type" selected>@type</option>
                                    }
                                    else
                                    {
                                        <option value="@type">@type</option>
                                    }
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label fw-bold filter-label"><i class="bi bi-cash-stack text-danger me-1"></i> Chi phí tối đa</label>
                    <input type="number" name="maxCost" value="@Context.Request.Query["maxCost"]" class="form-control form-control-lg border-0 shadow-sm filter-input" placeholder="VNĐ">
                </div>
                <div class="col-lg-1 col-md-2">
                    <button type="submit" class="btn w-100 h-100 d-flex align-items-center justify-content-center filter-submit-btn" aria-label="Lọc kết quả">
                        <i class="bi bi-funnel-fill"></i> <span class="d-md-none ms-2">Lọc</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="mb-4 text-end reveal">
            <a asp-action="Create" class="btn add-dest-btn">
                <i class="bi bi-plus-lg me-1"></i> Thêm địa điểm mới
            </a>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <form id="compare-form" asp-action="Compare" method="get" class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted small"><i class="bi bi-columns-gap me-1"></i>Chọn 2-3 điểm để so sánh:</span>
            <button type="submit" class="btn btn-sm rounded-pill compare-btn-gold" id="compare-btn" disabled>So sánh</button>
        </form>
        <div class="d-flex align-items-center gap-2">
            <label class="text-muted small fw-bold" for="sortOrder"><i class="bi bi-sort-down me-1"></i>Sắp xếp:</label>
            <select id="sortOrder" name="sortOrder" form="filter-form" class="form-select form-select-sm sort-select" onchange="document.getElementById('filter-form').submit()">
                @{ var currentSort = ViewBag.CurrentSort as string ?? "rating_desc"; }
                <option value="rating_desc" selected="@(currentSort == "rating_desc")">Đánh giá cao nhất</option>
                <option value="rating_asc" selected="@(currentSort == "rating_asc")">Đánh giá thấp nhất</option>
                <option value="cost_asc" selected="@(currentSort == "cost_asc")">Giá rẻ nhất</option>
                <option value="cost_desc" selected="@(currentSort == "cost_desc")">Giá cao nhất</option>
                <option value="name_asc" selected="@(currentSort == "name_asc")">Tên A-Z</option>
                <option value="name_desc" selected="@(currentSort == "name_desc")">Tên Z-A</option>
            </select>
        </div>
    </div>

    <!-- Destinations Grid -->
    <div class="dest-grid gs-reveal-container">
        @foreach (var item in Model)
        {
            <div class="dest-card custom-dark-card gs-reveal-item" onclick="location.href='@Url.Action("Details", new { id = item.Id })'">
                <div class="card-img-wrapper position-relative">
                    <label class="compare-check position-absolute top-0 start-0 m-2 compare-check-label" onclick="event.stopPropagation();">
                        <input type="checkbox" name="ids" value="@item.Id" form="compare-form" class="form-check-input compare-checkbox compare-chkbox" aria-label="Chọn so sánh @item.Name">
                    </label>
                    <div class="position-absolute top-0 end-0 m-2 compare-check-label" onclick="event.stopPropagation();">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            if (savedIds.Contains(item.Id))
                            {
                                <form asp-action="UnsaveDestination" method="post" class="m-0 p-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="destinationId" value="@item.Id" />
                                    <button type="submit" aria-label="Bỏ lưu @item.Name" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center bookmark-btn bookmark-btn-saved">
                                        <i class="bi bi-heart-fill"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="SaveDestination" method="post" class="m-0 p-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="destinationId" value="@item.Id" />
                                    <button type="submit" aria-label="Lưu @item.Name" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center bookmark-btn bookmark-btn-unsaved">
                                        <i class="bi bi-heart"></i>
                                    </button>
                                </form>
                            }
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" loading="lazy">
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center img-placeholder-bg">
                            <span class="text-muted opacity-50"><i class="bi bi-image img-placeholder-icon"></i></span>
                        </div>
                    }
                    <div class="card-img-overlay-hover">
                        <span class="btn-glass"><i class="bi bi-eye"></i> Khám phá</span>
                    </div>
                </div>
                <div class="dest-card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="dest-tag glass-tag"><i class="bi bi-tag-fill me-1"></i>@item.Type</span>
                        <span class="text-warning fw-bold glass-rating">
                            <i class="bi bi-star-fill me-1"></i> @item.AverageRating.ToString("0.0")
                        </span>
                    </div>
                    <h3 class="mt-2 text-white card-title-hover">@item.Name</h3>
                    <p class="mb-4 text-muted-custom">
                        @item.Description
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top-custom">
                        <span class="fw-medium text-location">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.Location
                        </span>
                        <span class="fw-bold text-price">
                            @if (item.EstimatedCost > 0)
                            {
                                @string.Format("{0:N0} đ", item.EstimatedCost)
                            }
                            else
                            {
                                <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Miễn phí</span>
                            }
                        </span>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mt-3 pt-3 border-top-custom d-flex justify-content-end gap-2" onclick="event.stopPropagation();">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light rounded-pill px-3"><i class="bi bi-pencil me-1"></i>Sửa</a>
                            <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa điểm đến này?');" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="bi bi-trash me-1"></i>Xóa</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
    
    @if (!Model.Any())
    {
        <div class="text-center py-5 reveal-scale rounded-4 shadow-sm empty-state-custom">
            <div class="mb-4">
                <i class="bi bi-search text-muted opacity-25 empty-state-search-icon"></i>
            </div>
            <h4 class="text-white fw-bold mb-3">Không tìm thấy địa điểm nào</h4>
            <p class="text-muted mb-4">Vui lòng thử lại với các tiêu chí tìm kiếm khác hoặc xóa bộ lọc.</p>
            <a asp-action="Index" class="btn btn-outline-danger rounded-pill px-4">
                <i class="bi bi-arrow-counterclockwise me-1"></i> Xóa bộ lọc
            </a>
        </div>
    }
</div>

@section Scripts {
    <!-- GSAP for advanced animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(ScrollTrigger);

            gsap.from(".hero-content > *", {
                y: 30, opacity: 0, duration: 1, stagger: 0.2, ease: "power3.out"
            });

            gsap.from(".reveal-scale", {
                scale: 0.9, opacity: 0, duration: 0.8, ease: "back.out(1.2)", delay: 0.5
            });

            gsap.from(".gs-reveal-item", {
                scrollTrigger: { trigger: ".gs-reveal-container", start: "top 85%" },
                y: 50, opacity: 0, duration: 0.8, stagger: 0.15, ease: "power2.out"
            });

            const checkboxes = document.querySelectorAll('.compare-checkbox');
            const compareBtn = document.getElementById('compare-btn');
            checkboxes.forEach(cb => {
                cb.addEventListener('change', () => {
                    let checked = document.querySelectorAll('.compare-checkbox:checked');
                    if (checked.length > 3) {
                        cb.checked = false;
                        alert('Bạn chỉ có thể so sánh tối đa 3 địa điểm.');
                        checked = document.querySelectorAll('.compare-checkbox:checked');
                    }
                    compareBtn.disabled = checked.length < 2;
                });
            });
        });
    </script>
}
