@model page.Models.Destination
@{
    ViewData["Title"] = "Xóa - " + Model.Name;
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/destinations.css" asp-append-version="true" />
}

<div class="section dest-delete-container">
    <div class="card border-0 text-center p-5 dest-delete-card">
        <i class="bi bi-exclamation-triangle text-danger fs-1 mb-3 d-block"></i>
        <h3 class="text-white fw-bold mb-3">Xác nhận xóa?</h3>
        <p class="text-muted mb-4">Bạn sắp xóa <strong class="text-white">@Model.Name</strong>. Hành động này không thể hoàn tác.</p>
        <form asp-action="Delete" method="post" class="d-flex gap-2 justify-content-center">
            <input type="hidden" asp-for="Id" />
            @Html.AntiForgeryToken()
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-light rounded-pill px-4">Hủy</a>
            <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Xóa vĩnh viễn</button>
        </form>
    </div>
</div>

