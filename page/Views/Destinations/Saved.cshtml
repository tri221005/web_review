@model IEnumerable<page.Models.SavedDestination>
@using Microsoft.AspNetCore.Identity
@inject UserManager<page.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Vali Ảo - Điểm Yêu Thích";
    Layout = "_Layout";
    var totalCost = (decimal)(ViewBag.TotalCost ?? 0m);
    var checklist = ViewBag.Checklist as List<string> ?? new List<string>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/saved.css" asp-append-version="true" />
}

<div class="section pt-4 saved-container">
    <div class="mb-4">
        <a asp-action="Index" class="btn rounded-pill btn-back-saved">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <h1 class="text-white fw-bold mb-4"><i class="bi bi-suitcase-lg-fill text-warning me-2"></i>Vali Ảo Của Bạn</h1>

            @if (Model.Any())
            {
                <div class="dest-grid">
                    @foreach (var item in Model)
                    {
                        var d = item.Destination!;
                        <div class="dest-card custom-dark-card saved-dest-card">
                            @if (!string.IsNullOrEmpty(d.ImageUrl))
                            {
                                <img src="@d.ImageUrl" alt="@d.Name" class="saved-dest-img">
                            }
                            <div class="p-3">
                                <h5 class="text-white fw-bold">@d.Name</h5>
                                <p class="small text-muted mb-2"><i class="bi bi-geo-alt text-danger"></i> @d.Location · @d.Type</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-warning fw-bold">@string.Format("{0:N0} đ", d.EstimatedCost)</span>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-sm btn-outline-light rounded-pill">Xem</a>
                                        <form asp-action="UnsaveDestination" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="destinationId" value="@d.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-heartbreak"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 rounded-4 saved-empty-state">
                    <i class="bi bi-heart fs-1 text-muted opacity-25 d-block mb-3"></i>
                    <p class="text-muted">Chưa có điểm yêu thích. Hãy khám phá và lưu những nơi bạn muốn đến!</p>
                    <a asp-action="Index" class="btn rounded-pill mt-2 btn-explore-now">Khám phá ngay</a>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 mb-4 saved-sidebar-card">
                <div class="card-body p-4">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-calculator text-warning me-2"></i>Tổng chi phí ước tính</h5>
                    <div class="display-6 fw-bold text-warning mb-0">@string.Format("{0:N0} VNĐ", totalCost)</div>
                    <p class="small text-muted mt-2">Dựa trên @Model.Count() điểm đã lưu</p>
                </div>
            </div>

            <div class="card border-0 saved-sidebar-card">
                <div class="card-body p-4">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-check2-square text-success me-2"></i>Checklist chuẩn bị</h5>
                    
                    <div class="input-group mb-3">
                        <input type="text" id="newItemInput" class="form-control checklist-input" placeholder="Thêm đồ cần mang...">
                        <button class="btn btn-outline-warning fw-bold" type="button" id="btnAddItem"><i class="bi bi-plus-lg"></i> Thêm</button>
                    </div>

                    <ul class="list-unstyled mb-0" id="checklistContainer">
                        <!-- Javascript will render items here -->
                    </ul>
                </div>
            </div>

            <div class="mt-4">
                <a href="#" onclick="alert('Tính năng Tạo lộ trình tự động đang được hệ thống nâng cấp và sẽ sớm ra mắt. Mong bạn thông cảm!'); return false;" class="btn w-100 rounded-pill py-2 fw-bold btn-route-soon">
                    <i class="bi bi-map me-1"></i> Tạo lộ trình từ vali ảo (Sắp ra mắt)
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const suggestedItems = @Html.Raw(Json.Serialize(checklist));
            const storageKey = 'user_checklist_@UserManager.GetUserId(User)';
            let checklistData = JSON.parse(localStorage.getItem(storageKey)) || [];

            suggestedItems.forEach(sName => {
                if (!checklistData.find(i => i.name === sName)) {
                    checklistData.push({ name: sName, isChecked: false });
                }
            });
            saveChecklist();

            const container = document.getElementById('checklistContainer');
            const input = document.getElementById('newItemInput');
            const btnAdd = document.getElementById('btnAddItem');

            function saveChecklist() {
                localStorage.setItem(storageKey, JSON.stringify(checklistData));
            }

            function renderChecklist() {
                container.innerHTML = '';
                if(checklistData.length === 0) {
                    container.innerHTML = '<li class="text-muted small text-center mt-3">Danh sách trống. Hãy thêm những món đồ cần thiết!</li>';
                    return;
                }

                checklistData.forEach((item, index) => {
                    const li = document.createElement('li');
                    li.className = 'checklist-item ' + (item.isChecked ? 'checked' : 'unchecked');

                    const itemContent = document.createElement('div');
                    itemContent.className = 'd-flex align-items-center flex-grow-1';
                    
                    if (item.isChecked) {
                        itemContent.innerHTML = `
                            <i class="bi bi-check-circle-fill text-success me-2 checklist-icon"></i>
                            <span class="checklist-text checked">${item.name}</span>
                        `;
                    } else {
                        itemContent.innerHTML = `
                            <i class="bi bi-circle text-danger me-2 checklist-icon"></i>
                            <span class="checklist-text">${item.name}</span>
                        `;
                    }

                    itemContent.onclick = () => {
                        item.isChecked = !item.isChecked;
                        saveChecklist();
                        renderChecklist();
                    };

                    const btnDelete = document.createElement('button');
                    btnDelete.className = 'btn-delete-checklist-item';
                    btnDelete.innerHTML = '<i class="bi bi-x-lg"></i>';
                    btnDelete.onclick = (e) => {
                        e.stopPropagation();
                        checklistData.splice(index, 1);
                        saveChecklist();
                        renderChecklist();
                    };

                    li.appendChild(itemContent);
                    li.appendChild(btnDelete);
                    container.appendChild(li);
                });
            }

            function addItem() {
                const val = input.value.trim();
                if (val) {
                    if (!checklistData.find(i => i.name.toLowerCase() === val.toLowerCase())) {
                        checklistData.push({ name: val, isChecked: false });
                        saveChecklist();
                        renderChecklist();
                        input.value = '';
                    } else {
                        alert('Món đồ này đã có trong danh sách!');
                    }
                }
            }

            btnAdd.addEventListener('click', addItem);
            input.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') addItem();
            });

            renderChecklist();
        });
    </script>
}
