@model page.Models.Destination
@{
    ViewData["Title"] = "Thêm Địa Điểm Mới";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/destinations.css" asp-append-version="true" />
}

<div class="section dest-form-container">
    <div class="container-fluid mx-auto dest-form-inner">
        
        <div class="mb-4 reveal">
            <a asp-action="Index" class="btn rounded-pill fw-medium btn-back-dest">
                <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
            </a>
        </div>

        <div class="card border-0 shadow-md reveal-scale dest-form-card">
            <div class="card-header text-white p-4 dest-form-header">
                <h3 class="mb-0 fw-bold d-flex align-items-center">
                    <i class="bi bi-map-fill text-warning me-3 fs-2"></i>
                    Thêm Địa Điểm Du Lịch Mới
                </h3>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0 shadow-sm"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label dest-form-label">Tên địa điểm</label>
                        <input asp-for="Name" class="form-control form-control-lg border-0 shadow-sm custom-dark-input" required placeholder="Nhập tên địa điểm..." />
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label dest-form-label">Khu vực</label>
                            <select asp-for="Location" class="form-select form-select-lg border-0 shadow-sm custom-dark-input">
                                <option value="Miền Bắc" class="bg-black">Miền Bắc</option>
                                <option value="Miền Trung" class="bg-black">Miền Trung</option>
                                <option value="Miền Nam" class="bg-black">Miền Nam</option>
                                <option value="Hà Nội" class="bg-black">Hà Nội</option>
                                <option value="TP.HCM" class="bg-black">TP.HCM</option>
                                <option value="Biển" class="bg-black">Biển</option>
                                <option value="Rừng" class="bg-black">Rừng</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label dest-form-label">Loại hình</label>
                            <select asp-for="Type" class="form-select form-select-lg border-0 shadow-sm custom-dark-input">
                                <option value="Thiên nhiên" class="bg-black">Thiên nhiên</option>
                                <option value="Di tích lịch sử" class="bg-black">Di tích lịch sử</option>
                                <option value="Văn hóa" class="bg-black">Văn hóa</option>
                                <option value="Nghỉ dưỡng" class="bg-black">Nghỉ dưỡng</option>
                                <option value="Ẩm thực" class="bg-black">Ẩm thực</option>
                                <option value="Biển" class="bg-black">Biển</option>
                                <option value="Rừng" class="bg-black">Rừng</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="EstimatedCost" class="form-label dest-form-label">Chi phí dự kiến (VNĐ)</label>
                        <div class="input-group shadow-sm estimated-cost-group">
                            <span class="input-group-text border-0 estimated-cost-addon"><i class="bi bi-cash-stack"></i></span>
                            <input asp-for="EstimatedCost" type="number" class="form-control form-control-lg border-0 custom-dark-input" placeholder="0" />
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label dest-form-label">Hình ảnh minh họa (URL hoặc Tải file lên)</label>
                        <div class="d-flex flex-column gap-3">
                            <div class="input-group shadow-sm estimated-cost-group">
                                <span class="input-group-text border-0 estimated-cost-addon"><i class="bi bi-link-45deg"></i></span>
                                <input asp-for="ImageUrl" class="form-control form-control-lg border-0 custom-dark-input" placeholder="Nhập đường dẫn URL (nếu có)..." />
                            </div>
                            <div class="input-group shadow-sm estimated-cost-group">
                                <span class="input-group-text border-0 estimated-cost-addon"><i class="bi bi-upload"></i></span>
                                <input asp-for="ImageFile" type="file" accept="image/*" class="form-control form-control-lg border-0 custom-dark-input" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label asp-for="Description" class="form-label dest-form-label">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="form-control form-control-lg border-0 shadow-sm custom-dark-input dest-form-textarea" rows="6" required placeholder="Viết một đoạn mô tả hấp dẫn..."></textarea>
                    </div>
                    
                    <div class="d-flex justify-content-end gap-3 pt-4 dest-form-footer">
                        <button type="button" class="btn rounded-pill px-4 fw-bold shadow-sm custom-cancel-btn" onclick="window.location.href='@Url.Action("Index")'">Hủy</button>
                        <button type="submit" class="btn rounded-pill px-5 fw-bold shadow-sm btn-primary-gradient">
                            <i class="bi bi-check2-circle me-1"></i> Lưu địa điểm
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
