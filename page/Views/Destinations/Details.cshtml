@model page.Models.Destination
@using Microsoft.AspNetCore.Identity
@inject UserManager<page.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = Model.Name;
    Layout = "_Layout";
    var bgImageUrl = !string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?auto=format&fit=crop&q=80";
    var isSaved = ViewBag.IsSaved as bool? ?? false;
    var isVisited = ViewBag.IsVisited as bool? ?? false;
    var sentimentTags = ViewBag.SentimentTags as Dictionary<string, int> ?? new Dictionary<string, int>();
    var heritageTimeline = ViewBag.HeritageTimeline as List<page.Controllers.HeritageTimelineEntry> ?? new List<page.Controllers.HeritageTimelineEntry>();
    var recentStories = ViewBag.RecentStories as List<page.Models.TravelStory> ?? new List<page.Models.TravelStory>();
}

@functions {
    public string FormatUserName(string? fullName, string? userName)
    {
        if (!string.IsNullOrEmpty(fullName)) return fullName;
        if (string.IsNullOrEmpty(userName)) return "Ẩn danh";
        
        if (userName.Contains("@"))
        {
            var parts = userName.Split('@');
            if (parts[0].Length <= 2) return userName.Substring(0, 1) + "***@" + parts[1];
            return parts[0].Substring(0, 2) + "***@" + parts[1];
        }
        return userName;
    }

    public string GetRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;
        if (timeSpan <= TimeSpan.FromSeconds(60)) return "Vừa xong";
        if (timeSpan <= TimeSpan.FromMinutes(60)) return $"{timeSpan.Minutes} phút trước";
        if (timeSpan <= TimeSpan.FromHours(24)) return $"{timeSpan.Hours} giờ trước";
        if (timeSpan <= TimeSpan.FromDays(30)) return $"{timeSpan.Days} ngày trước";
        if (timeSpan <= TimeSpan.FromDays(365)) return $"{timeSpan.Days / 30} tháng trước";
        return $"{timeSpan.Days / 365} năm trước";
    }
}

<div class="section destination-details-section">
    <div class="container-fluid p-0 destination-container">
        <div class="mb-4 reveal">
            <a asp-action="Index" class="btn rounded-pill fw-medium btn-back-list"><i class="bi bi-arrow-left me-1"></i> Quay lại danh sách</a>
        </div>
        
        <div class="mb-5 reveal text-white">
            <div class="badge px-3 py-2 rounded-pill mb-3 badge-location"><i class="bi bi-geo-alt-fill text-danger me-1"></i> @Model.Location</div>
            <h1 class="fw-bold mb-3 dest-details-title">@Model.Name</h1>
            <div class="d-flex flex-wrap gap-3">
                <span class="badge bg-danger px-4 py-2 rounded-pill fs-6 fw-medium shadow-sm"><i class="bi bi-tag-fill me-1"></i> @Model.Type</span>
                <span class="badge bg-warning text-dark px-4 py-2 rounded-pill fs-6 fw-bold shadow-sm"><i class="bi bi-star-fill me-1"></i> @Model.AverageRating.ToString("0.0")</span>
            </div>
        </div>
        
        <div class="row g-4">
            <!-- Main Content -->
            <div class="col-lg-8 reveal-left">
                <div class="card border-0 mb-4 shadow-sm destination-glass-card">
                    <div class="row g-0">
                        <div class="col-md-5">
                            <img src="@bgImageUrl" alt="@Model.Name" class="img-fluid h-100 destination-hero-img" />
                        </div>
                        <div class="col-md-7">
                            <div class="card-body p-4 p-md-5">
                                <h3 class="fw-bold mb-4 text-white details-info-header"><i class="bi bi-info-circle text-danger me-2"></i>Thông tin chi tiết</h3>
                                
                                <div class="d-flex flex-wrap gap-4 mb-4 pb-4 details-info-divider">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-danger me-3 shadow-sm info-circle-icon">
                                            <i class="bi bi-cash-stack fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="small fw-bold text-uppercase letter-spacing-1 details-info-label">Chi phí dự kiến</div>
                                            <div class="fw-bold fs-5 details-info-value-gold">
                                                @if (Model.EstimatedCost > 0)
                                                {
                                                    @string.Format("{0:N0} VNĐ", Model.EstimatedCost)
                                                }
                                                else
                                                {
                                                    <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Miễn phí</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-danger me-3 shadow-sm info-circle-icon">
                                            <i class="bi bi-people fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="small fw-bold text-uppercase letter-spacing-1 details-info-label">Đánh giá</div>
                                            <div class="fw-bold text-white fs-5">@(Model.Reviews?.Count ?? 0) người</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="description-content">@Model.Description</div>

                                @if (sentimentTags.Any())
                                {
                                    <div class="mt-4 pt-4 review-highlights-divider">
                                        <h5 class="text-white fw-bold mb-3"><i class="bi bi-tags text-warning me-2"></i>Điểm nổi bật từ đánh giá</h5>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var tag in sentimentTags)
                                            {
                                                <span class="badge rounded-pill px-3 py-2 sentiment-badge">
                                                    @tag.Key (@tag.Value)
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="card border-0 mb-4 shadow-sm destination-glass-card">
                        <div class="card-body p-4">
                            <h3 class="fw-bold mb-3 text-white"><i class="bi bi-images text-danger me-2"></i>Thư viện ảnh</h3>
                            <div class="row g-2">
                                @foreach (var img in Model.Images.OrderBy(i => i.SortOrder))
                                {
                                    <div class="col-4 col-md-3">
                                        <a href="@img.Url" target="_blank">
                                            <img src="@img.Url" alt="@(img.Caption ?? Model.Name)" class="img-fluid rounded-3 gallery-img">
                                        </a>
                                        @if (!string.IsNullOrEmpty(img.Caption))
                                        {
                                            <div class="small text-muted mt-1 text-center">@img.Caption</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }



                @if (heritageTimeline.Any())
                {
                    <div class="card border-0 mb-4 shadow-sm destination-glass-card">
                        <div class="card-body p-4 p-md-5">
                            <h3 class="fw-bold mb-4 text-white"><i class="bi bi-clock-history text-danger me-2"></i>Di Sản Qua Các Thời Kỳ</h3>
                            <div class="heritage-timeline">
                                @foreach (var entry in heritageTimeline)
                                {
                                    <div class="timeline-item mb-4 ps-4 border-start border-warning timeline-item-border">
                                        <div class="small text-warning fw-bold">@entry.Year</div>
                                        <div class="text-white fw-bold">@entry.Title</div>
                                        <div class="text-muted small">@entry.Description</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (recentStories.Any())
                {
                    <div class="card border-0 mb-4 destination-glass-card">
                        <div class="card-body p-4">
                            <h4 class="text-white fw-bold mb-3"><i class="bi bi-journal-text text-danger me-2"></i>Câu chuyện từ du khách</h4>
                            @foreach (var story in recentStories)
                            {
                                <div class="mb-3 pb-3 border-bottom story-item-divider">
                                    <div class="fw-bold text-white">@story.Title</div>
                                    <div class="small text-muted mb-1">@(story.User?.FullName ?? story.User?.UserName) · @story.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <p class="text-muted small mb-0">@(story.Content.Length > 150 ? story.Content.Substring(0, 150) + "..." : story.Content)</p>
                                </div>
                            }
                            <a asp-controller="Stories" asp-action="Index" class="btn btn-sm btn-outline-light rounded-pill">Xem tất cả</a>
                        </div>
                    </div>
                }

            <!-- Sidebar -->
            <div class="col-lg-4 reveal-right">
                <!-- Action Card -->
                <div class="card border-0 mb-4 shadow-md destination-glass-card">
                    <div class="card-body p-4 text-center">
                        <div class="display-3 fw-bold text-warning mb-1 avg-rating-text">@Model.AverageRating.ToString("0.0")</div>
                        <div class="text-warning mb-2 fs-5">
                            @for(int i=1; i<=5; i++) {
                                if (i <= Math.Round(Model.AverageRating)) { <i class="bi bi-star-fill"></i> }
                                else { <i class="bi bi-star"></i> }
                            }
                        </div>
                        <p class="small mb-4 avg-rating-muted-lbl">Dựa trên @(Model.Reviews?.Count ?? 0) đánh giá từ người dùng</p>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (!isVisited)
                            {
                                <form asp-action="MarkVisited" method="post" class="mb-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="destinationId" value="@Model.Id" />
                                    <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold shadow-lg btn-visited-action">
                                        <i class="bi bi-patch-check-fill me-2"></i> Đánh dấu đã đến
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="alert py-3 mb-3 rounded-pill text-center fw-bold visited-alert-badge">
                                    <i class="bi bi-patch-check-fill me-2"></i> Đã có mặt trong Hộ chiếu
                                </div>
                            }

                            <div class="d-flex gap-2 mb-2">
                                @if (isSaved)
                                {
                                    <form asp-action="UnsaveDestination" method="post" class="flex-grow-1 m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="destinationId" value="@Model.Id" />
                                        <button type="submit" class="btn w-100 rounded-pill py-2 fw-medium btn-sidebar-save">
                                            <i class="bi bi-heart-fill text-danger me-1"></i> Đã lưu
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="SaveDestination" method="post" class="flex-grow-1 m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="destinationId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-outline-light w-100 rounded-pill py-2 fw-medium btn-sidebar-unsave">
                                            <i class="bi bi-heart me-1"></i> Lưu lại
                                        </button>
                                    </form>
                                }

                                <a asp-controller="Passport" asp-action="Index" class="btn w-100 rounded-pill py-2 flex-grow-1 fw-medium btn-sidebar-passport">
                                    <i class="bi bi-passport me-1"></i> Hộ chiếu
                                </a>
                            </div>
                        }
                        else
                        {
                            <a href="/Identity/Account/Login" class="btn w-100 rounded-pill py-3 fw-bold shadow-sm btn-sidebar-login">
                                Khám Phá Cùng Chúng Tôi
                            </a>
                        }
                    </div>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="card border-0 mb-4 destination-glass-card">
                        <div class="card-body p-4">
                            <h5 class="text-white fw-bold mb-3"><i class="bi bi-shield-lock text-warning me-2"></i>Quản trị</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light rounded-pill"><i class="bi bi-pencil me-1"></i>Sửa</a>

                                <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa điểm đến này?');" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash me-1"></i>Xóa</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Reviews Section (Full Width) -->
        <div class="card border-0 shadow-sm mt-4 reveal destination-glass-card">
            <div class="card-header border-bottom-0 pt-4 pb-0 px-4 reviews-card-header">
                <h4 class="fw-bold mb-0 text-white"><i class="bi bi-chat-square-text text-danger me-2"></i>Cộng đồng đánh giá</h4>
            </div>
            <div class="card-body p-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var currentUserId = UserManager.GetUserId(User);
                    var hasReviewed = Model.Reviews != null && Model.Reviews.Any(r => r.UserId == currentUserId);

                    if (hasReviewed)
                    {
                        <div class="alert border rounded-4 text-center mb-4 py-3 review-info-alert">
                            Bạn đã đánh giá địa điểm này. Cảm ơn sự đóng góp của bạn!
                        </div>
                    }
                    else
                    {
                        <form id="reviewForm" asp-action="AddReview" method="post" class="mb-5 mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="destinationId" value="@Model.Id" />
                            <div class="mb-3 d-flex align-items-center gap-3">
                                <label class="form-label fw-bold mb-0 review-label-muted">Chấm điểm:</label>
                                <div class="rating-input d-flex flex-row-reverse justify-content-end gap-1">
                                    <input type="radio" name="rating" value="5" id="star5" required><label for="star5" class="bi bi-star-fill fs-4 cursor-pointer"></label>
                                    <input type="radio" name="rating" value="4" id="star4"><label for="star4" class="bi bi-star-fill fs-4 cursor-pointer"></label>
                                    <input type="radio" name="rating" value="3" id="star3"><label for="star3" class="bi bi-star-fill fs-4 cursor-pointer"></label>
                                    <input type="radio" name="rating" value="2" id="star2"><label for="star2" class="bi bi-star-fill fs-4 cursor-pointer"></label>
                                    <input type="radio" name="rating" value="1" id="star1"><label for="star1" class="bi bi-star-fill fs-4 cursor-pointer"></label>
                                </div>

                                    
                                    
                                    
                                    
                                    

                            </div>
                            <div class="mb-4 comment-textarea-wrapper">
                                <textarea id="reviewComment" name="comment" class="form-control shadow-none border-0 comment-textarea" rows="3" placeholder="Chia sẻ trải nghiệm của bạn (nhấn để AI hỗ trợ viết)..." required></textarea>
                                <button type="button" id="btnAIEnhance" class="btn btn-sm position-absolute bottom-0 end-0 m-2 rounded-pill btn-ai-enhance">
                                    <i class="bi bi-magic text-warning me-1"></i> Làm mượt
                                </button>
                            </div>
                            <button type="submit" class="btn rounded-pill fw-medium btn-submit-review">Gửi đánh giá</button>
                        </form>
                    }
                }
                else
                {
                    <div class="alert border rounded-4 text-center mb-4 py-3 review-info-alert">
                        Vui lòng <a href="/Identity/Account/Login" class="fw-bold text-danger text-decoration-none">đăng nhập</a> để chia sẻ trải nghiệm.
                    </div>
                }

                <div class="review-list custom-scrollbar pe-2 review-list-container">
                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="mb-4 pb-3 border-bottom review-item-divider">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="avatar bg-danger text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm review-avatar-bg">
                                        @FormatUserName(review.User?.FullName, review.User?.UserName).Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold text-white review-author-name">@FormatUserName(review.User?.FullName, review.User?.UserName)</div>
                                        <div class="review-time-muted">@GetRelativeTime(review.CreatedAt)</div>
                                    </div>
                                    <div class="ms-auto text-warning fs-5">
                                        @for(int i=0; i<review.Rating; i++) { <i class="bi bi-star-fill"></i> }
                                        @for(int i=review.Rating; i<5; i++) { <i class="bi bi-star review-stars-muted"></i> }
                                    </div>
                                </div>
                                <div id="review-text-@review.Id" class="mb-0 mt-2 review-comment-text">@review.Comment</div>
                                
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-2 mt-2 review-admin-actions">
                                        <button type="button" class="btn btn-sm btn-outline-light rounded-pill" onclick="document.getElementById('edit-form-@review.Id').style.display='block'; document.getElementById('review-text-@review.Id').style.display='none';"><i class="bi bi-pencil"></i> Sửa</button>
                                        <form asp-action="DeleteReview" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đánh giá này?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="reviewId" value="@review.Id" />
                                            <input type="hidden" name="destinationId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash"></i> Xóa</button>
                                        </form>
                                    </div>
                                    <form id="edit-form-@review.Id" asp-action="EditReview" method="post" style="display: none;" class="mt-2 review-edit-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="reviewId" value="@review.Id" />
                                        <input type="hidden" name="destinationId" value="@Model.Id" />
                                        <div class="d-flex flex-column gap-2">
                                            <textarea name="comment" class="form-control border-0 shadow-sm custom-dark-input review-edit-textarea" rows="2">@review.Comment</textarea>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm btn-warning rounded-pill px-3" type="submit">Lưu</button>
                                                <button class="btn btn-sm btn-secondary rounded-pill px-3" type="button" onclick="document.getElementById('edit-form-@review.Id').style.display='none'; document.getElementById('review-text-@review.Id').style.display='block';">Hủy</button>
                                            </div>
                                        </div>
                                    </form>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 reviews-empty-state">
                            <i class="bi bi-chat-left-dots fs-1 opacity-25 mb-3 d-block"></i>
                            Chưa có đánh giá nào.<br>Hãy là người đầu tiên!
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btnEnhance = document.getElementById('btnAIEnhance');
            const txtComment = document.getElementById('reviewComment');
            
            if (btnEnhance && txtComment) {
                txtComment.addEventListener('input', function() {
                    if (this.value.trim().length > 0) {
                        btnEnhance.style.display = 'inline-block';
                    } else {
                        btnEnhance.style.display = 'none';
                    }
                });

                btnEnhance.addEventListener('click', function () {
                    const keywords = txtComment.value;
                    if (!keywords.trim()) {
                        alert('Vui lòng gõ vài từ khóa (vd: đẹp, ngon) trước khi nhờ AI viết!');
                        return;
                    }
                    
                    const originalHtml = btnEnhance.innerHTML;
                    btnEnhance.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Đang viết...';
                    btnEnhance.disabled = true;

                    fetch('/Destinations/EnhanceReview', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ keywords: keywords })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            txtComment.value = '';
                            let i = 0;
                            const text = data.enhancedText;
                            const speed = 25; // ms per char
                            
                            function typeWriter() {
                                if (i < text.length) {
                                    txtComment.value += text.charAt(i);
                                    i++;
                                    setTimeout(typeWriter, speed);
                                } else {
                                    btnEnhance.innerHTML = originalHtml;
                                    btnEnhance.disabled = false;
                                }
                            }
                            typeWriter();
                        } else {
                            btnEnhance.innerHTML = originalHtml;
                            btnEnhance.disabled = false;
                            alert(data.enhancedText || data.message || 'Có lỗi xảy ra khi gọi AI.');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        btnEnhance.innerHTML = originalHtml;
                        btnEnhance.disabled = false;
                        alert('Có lỗi kết nối hệ thống AI.');
                    });
                });
            }
        });
    </script>
}
@section Styles {
    <link rel="stylesheet" href="~/css/details.css" asp-append-version="true" />
}
