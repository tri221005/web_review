@model page.Models.Destination
@{
    ViewData["Title"] = "Sửa - " + Model.Name;
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/destinations.css" asp-append-version="true" />
}

<div class="section dest-form-container">
    <div class="container-fluid mx-auto dest-form-inner">
        <div class="mb-4">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn rounded-pill btn-back-dest">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
        </div>

        <div class="card border-0 dest-form-card">
            <div class="card-body p-4 p-md-5">
                <h3 class="text-white fw-bold mb-4">Sửa điểm đến</h3>
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label dest-form-label">Tên</label>
                        <input asp-for="Name" class="form-control custom-dark-input" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label dest-form-label">Khu vực</label>
                            <select asp-for="Location" class="form-select custom-dark-input">
                                <option value="Miền Bắc" class="bg-black">Miền Bắc</option>
                                <option value="Miền Trung" class="bg-black">Miền Trung</option>
                                <option value="Miền Nam" class="bg-black">Miền Nam</option>
                                <option value="Hà Nội" class="bg-black">Hà Nội</option>
                                <option value="TP.HCM" class="bg-black">TP.HCM</option>
                                <option value="Biển" class="bg-black">Biển</option>
                                <option value="Rừng" class="bg-black">Rừng</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label dest-form-label">Loại hình</label>
                            <select asp-for="Type" class="form-select custom-dark-input">
                                <option value="Thiên nhiên" class="bg-black">Thiên nhiên</option>
                                <option value="Di tích lịch sử" class="bg-black">Di tích lịch sử</option>
                                <option value="Văn hóa" class="bg-black">Văn hóa</option>
                                <option value="Nghỉ dưỡng" class="bg-black">Nghỉ dưỡng</option>
                                <option value="Ẩm thực" class="bg-black">Ẩm thực</option>
                                <option value="Biển" class="bg-black">Biển</option>
                                <option value="Rừng" class="bg-black">Rừng</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="EstimatedCost" class="form-label dest-form-label">Chi phí</label>
                            <input asp-for="EstimatedCost" type="number" class="form-control custom-dark-input" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Latitude" class="form-label dest-form-label">Vĩ độ</label>
                            <input asp-for="Latitude" type="number" step="any" class="form-control custom-dark-input" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Longitude" class="form-label dest-form-label">Kinh độ</label>
                            <input asp-for="Longitude" type="number" step="any" class="form-control custom-dark-input" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LandingSceneKey" class="form-label dest-form-label">Landing Scene Key</label>
                        <input asp-for="LandingSceneKey" class="form-control custom-dark-input" placeholder="hanoi, halong, hue..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label dest-form-label">Hình ảnh (URL hoặc Tải lên)</label>
                        <div class="d-flex flex-column gap-2">
                            <input asp-for="ImageUrl" class="form-control custom-dark-input" placeholder="Nhập đường dẫn URL (nếu có)..." />
                            <input asp-for="ImageFile" type="file" accept="image/*" class="form-control custom-dark-input" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HeritageTimelineJson" class="form-label dest-form-label">Timeline di sản (JSON)</label>
                        <textarea asp-for="HeritageTimelineJson" rows="4" class="form-control custom-dark-input"></textarea>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label dest-form-label">Mô tả</label>
                        <textarea asp-for="Description" rows="5" class="form-control custom-dark-input"></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger rounded-pill">Xóa</a>
                        <button type="submit" class="btn rounded-pill px-4 btn-save-gold">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

