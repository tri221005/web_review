@model List<page.Models.Destination>
@{
    ViewData["Title"] = "So Sánh Điểm Đến";
    Layout = "_Layout";
    var cheapest = Model.OrderBy(d => d.EstimatedCost).FirstOrDefault();
    var bestRated = Model.OrderByDescending(d => d.AverageRating).FirstOrDefault();
}

<div class="section pt-4" style="max-width: 1100px; margin: 0 auto; padding: 0 15px 5rem;">
    <div class="mb-4">
        <a asp-action="Index" class="btn rounded-pill" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white;">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <h1 class="text-white fw-bold mb-4"><i class="bi bi-columns-gap text-warning me-2"></i>So Sánh Điểm Đến</h1>

    @if (Model.Count >= 2)
    {
        <div class="table-responsive">
            <table class="table table-dark table-bordered align-middle" style="background: rgba(20,20,25,0.8); border-color: rgba(255,255,255,0.1) !important;">
                <thead>
                    <tr>
                        <th style="width: 180px;">Tiêu chí</th>
                        @foreach (var d in Model)
                        {
                            <th>@d.Name</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr><td>Khu vực</td>@foreach (var d in Model) { <td>@d.Location</td> }</tr>
                    <tr><td>Loại hình</td>@foreach (var d in Model) { <td>@d.Type</td> }</tr>
                    <tr><td>Chi phí</td>@foreach (var d in Model) { <td class="text-warning fw-bold">@string.Format("{0:N0} đ", d.EstimatedCost)</td> }</tr>
                    <tr><td>Đánh giá</td>@foreach (var d in Model) { <td><i class="bi bi-star-fill text-warning"></i> @d.AverageRating.ToString("0.0") (@d.ReviewCount)</td> }</tr>
                    <tr>
                        <td></td>
                        @foreach (var d in Model)
                        {
                            <td><a asp-action="Details" asp-route-id="@d.Id" class="btn btn-sm btn-outline-light rounded-pill">Chi tiết</a></td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>

        @if (cheapest != null && bestRated != null)
        {
        <div class="alert mt-4" style="background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.3); color: #ddd;">
            <strong class="text-warning">Gợi ý:</strong>
            @cheapest.Name rẻ nhất (@string.Format("{0:N0} đ", cheapest.EstimatedCost)).
            @if (bestRated.Id != cheapest.Id)
            {
                <span>@bestRated.Name có rating cao nhất (@bestRated.AverageRating.ToString("0.0") sao).</span>
            }
        </div>
        }
    }
</div>
