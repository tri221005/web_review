/* SCROLL CONTENT CONTAINER */
.scroll-content { position: relative; z-index: 10; pointer-events: none; }
.glass-card, .solid-wrapper, .premium-nav, #preloader, .btn-solid, .btn-play-video { pointer-events: auto; }

/* HERO SECTION */
.hero-content { text-align: center; }
.badge {
    display: inline-block; padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.2); border-radius: 50px;
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.2em;
    margin-bottom: 2rem; backdrop-filter: blur(5px); color: #fff;
}
.hero-title {
