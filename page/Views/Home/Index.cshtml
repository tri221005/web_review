@model page.Models.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Việt Nam - Hành Trình Di Sản";
    Layout = "_LandingLayout";
    var sceneLinksJson = System.Text.Json.JsonSerializer.Serialize(Model.SceneLinks);
}

<!-- PRELOADER -->
<div id="preloader" role="status" aria-busy="true">
    <div class="loader-content">
        <h2 class="loader-title">VIỆT NAM</h2>
        <div class="progress-bar"><div class="progress" id="progress-bar"></div></div>
        <div class="loading-text">ĐANG TẢI...</div>
    </div>
</div>

<!-- NAVBAR -->
<nav class="premium-nav" id="navbar">
    <div class="nav-brand">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        <span>Việt Nam</span>
    </div>
    <button class="mobile-nav-toggle" id="landingNavToggle" aria-label="Mở menu điều hướng" aria-expanded="false">
        <i class="bi bi-list" aria-hidden="true"></i>
    </button>
    <ul class="nav-links" id="landingNavLinks">
        <li><a href="/Destinations" class="btn-outline">Khám Phá Điểm Đến</a></li>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <li><a href="/Profile">Hồ Sơ</a></li>
            <li>
                <form class="form-inline m-0 nav-logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="nav-logout-btn">Đăng Xuất</button>
                </form>
            </li>
        }
        else
        {
            <li><a href="/Identity/Account/Login">Đăng Nhập</a></li>
            <li><a href="/Identity/Account/Register">Đăng Ký</a></li>
        }
    </ul>
    <style>
        @@media (max-width: 767px) {
            #landingNavLinks { display: none; position: fixed; top: 70px; left: 0; width: 100%; flex-direction: column; background: rgba(0,0,0,0.98); backdrop-filter: blur(12px); padding: 1.5rem; gap: 1rem; border-bottom: 1px solid rgba(255,255,255,0.05); z-index: 1000; margin: 0; }
            #landingNavLinks.show { display: flex !important; }
            #landingNavLinks li { width: 100%; text-align: center; }
        }
        @@media (min-width: 768px) {
            #landingNavToggle { display: none !important; }
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toggle = document.getElementById('landingNavToggle');
            var navLinks = document.getElementById('landingNavLinks');
            if (toggle && navLinks) {
                toggle.addEventListener('click', function() {
                    var isExpanded = toggle.getAttribute('aria-expanded') === 'true';
                    toggle.setAttribute('aria-expanded', !isExpanded);
                    navLinks.classList.toggle('show');
                    var icon = toggle.querySelector('i');
                    if (icon) { icon.classList.toggle('bi-list'); icon.classList.toggle('bi-x-lg'); }
                });
            }
        });
    </script>
</nav>

<!-- FIXED VIDEO BACKGROUNDS -->
<div id="media-container">
    <!-- 1. Intro Việt Nam -->
    <img id="vid-1" src="https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?auto=format&fit=crop&q=80" class="bg-video" alt="Vietnam Intro">
    <!-- 2. Hà Nội -->
    <video id="vid-2" loop muted playsinline class="bg-video" preload="none">
        <source src="/videos/hanoi.mp4" type="video/mp4">
    </video>
    <!-- 3. Vịnh Hạ Long -->
    <video id="vid-3" loop muted playsinline class="bg-video" preload="none">
        <source src="/videos/vinhhalong.mp4" type="video/mp4">
    </video>
    <!-- 4. Huế -->
    <video id="vid-4" loop muted playsinline class="bg-video" preload="none">
        <source src="/videos/heu.mp4" type="video/mp4">
    </video>
    <!-- 5. Hội An -->
    <video id="vid-5" loop muted playsinline class="bg-video" preload="none">
        <source src="/videos/hoian.mp4" type="video/mp4">
    </video>
    <!-- 6. Đà Lạt -->
    <video id="vid-6" loop muted playsinline class="bg-video" preload="none">
        <source src="/videos/datlat.mp4" type="video/mp4">
    </video>
    <!-- 7. TP.HCM -->
    <video id="vid-7" loop muted playsinline class="bg-video" preload="none">
        <source src="/videos/hcm.mp4" type="video/mp4">
    </video>
    <!-- 8. Phú Quốc -->
    <video id="vid-8" loop muted playsinline class="bg-video" preload="none">
        <source src="/videos/phuquoc.mp4" type="video/mp4">
    </video>
    
    <!-- Gradient Overlay to make text pop -->
    <div class="vignette-overlay"></div>
</div>

<!-- SCROLLING CONTENT -->
<main class="scroll-content">
    
    <!-- 1. HERO / INTRO -->
    <section class="story-panel align-center" id="scene-1">
        <div class="hero-content">
            <h1 class="hero-title">VIỆT NAM</h1>
            <p class="hero-subtitle">Hành Trình Chạm Vào Di Sản</p>
        </div>
        <div class="scroll-indicator">
            <div class="mouse"></div>
            <p>Cuộn xuống</p>
        </div>
    </section>

    <!-- 2. HÀ NỘI -->
    <section class="story-panel align-left" id="scene-2">
        <div class="glass-card">
            <div class="chapter">Chương 01 / Thủ Đô</div>
            <h2>Hà Nội<br><span>Ngàn Năm Văn Hiến</span></h2>
            <p>Nhịp sống phố cổ đan xen giữa sự hối hả hiện đại và nét trầm mặc của lịch sử. Dạo bước qua 36 phố phường, thưởng thức tách cà phê trứng và cảm nhận nhịp đập của thủ đô.</p>
            <div class="action-buttons">
                <button class="btn-play-video" data-target="vid-2" aria-label="Xem video về Hà Nội">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg> Xem Video
                </button>
                <button class="btn-history" data-location="hanoi" aria-label="Tìm hiểu lịch sử Hà Nội">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Tìm Hiểu Lịch Sử
                </button>
            </div>
        </div>
    </section>

    <!-- 3. VỊNH HẠ LONG -->
    <section class="story-panel align-right" id="scene-3">
        <div class="glass-card">
            <div class="chapter">Chương 02 / Di Sản Thiên Nhiên</div>
            <h2>Vịnh Hạ Long<br><span>Kỳ Quan Biển Cả</span></h2>
            <p>Hàng ngàn hòn đảo đá vôi vươn lên từ mặt nước xanh ngọc bích. Một bức tranh thủy mặc vĩ đại mà thiên nhiên ban tặng, mang đến sự choáng ngợp và yên bình.</p>
            <div class="action-buttons">
                <button class="btn-play-video" data-target="vid-3" aria-label="Xem video về Vịnh Hạ Long">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg> Xem Video
                </button>
                <button class="btn-history" data-location="halong" aria-label="Tìm hiểu lịch sử Vịnh Hạ Long">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Tìm Hiểu Lịch Sử
                </button>
            </div>
        </div>
    </section>

    <!-- 4. HUẾ -->
    <section class="story-panel align-left" id="scene-4">
        <div class="glass-card">
            <div class="chapter">Chương 03 / Cố Đô</div>
            <h2>Huế<br><span>Dấu Ấn Thời Gian</span></h2>
            <p>Lăng tẩm uy nghi, Đại Nội trầm mặc và dòng Hương Giang lững lờ trôi. Nơi lưu giữ trọn vẹn hồn cốt của những triều đại huy hoàng xưa cũ.</p>
            <div class="action-buttons">
                <button class="btn-play-video" data-target="vid-4" aria-label="Xem video về Huế">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg> Xem Video
                </button>
                <button class="btn-history" data-location="hue" aria-label="Tìm hiểu lịch sử Huế">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Tìm Hiểu Lịch Sử
                </button>
            </div>
        </div>
    </section>

    <!-- 5. HỘI AN -->
    <section class="story-panel align-right" id="scene-5">
        <div class="glass-card">
            <div class="chapter">Chương 04 / Phố Cổ</div>
            <h2>Hội An<br><span>Đêm Lung Linh</span></h2>
            <p>Những nếp nhà ngói rêu phong và con hẻm rực rỡ sắc lồng đèn. Hội An đưa ta về một thời thương cảng sầm uất, lãng mạn và đầy hoài niệm.</p>
            <div class="action-buttons">
                <button class="btn-play-video" data-target="vid-5" aria-label="Xem video về Hội An">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg> Xem Video
                </button>
                <button class="btn-history" data-location="hoian" aria-label="Tìm hiểu lịch sử Hội An">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Tìm Hiểu Lịch Sử
                </button>
            </div>
        </div>
    </section>

    <!-- 6. ĐÀ LẠT -->
    <section class="story-panel align-left" id="scene-6">
        <div class="glass-card">
            <div class="chapter">Chương 05 / Cao Nguyên</div>
            <h2>Đà Lạt<br><span>Thành Phố Ngàn Hoa</span></h2>
            <p>Ẩn mình trong sương sớm và những đồi thông reo. Đà Lạt mang nhịp thở của sự lãng mạn, thanh bình, làm xao xuyến bất cứ ai đặt chân đến.</p>
            <div class="action-buttons">
                <button class="btn-play-video" data-target="vid-6" aria-label="Xem video về Đà Lạt">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg> Xem Video
                </button>
                <button class="btn-history" data-location="dalat" aria-label="Tìm hiểu lịch sử Đà Lạt">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Tìm Hiểu Lịch Sử
                </button>
            </div>
        </div>
    </section>

    <!-- 7. TP.HCM -->
    <section class="story-panel align-right" id="scene-7">
        <div class="glass-card">
            <div class="chapter">Chương 06 / Đô Thị</div>
            <h2>TP.HCM<br><span>Thành Phố Không Ngủ</span></h2>
            <p>Sự chuyển mình mạnh mẽ của một trung tâm kinh tế năng động. Rực rỡ ánh đèn về đêm, Sài Gòn là bản giao hưởng của sự trẻ trung và sáng tạo.</p>
            <div class="action-buttons">
                <button class="btn-play-video" data-target="vid-7" aria-label="Xem video về TP.HCM">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg> Xem Video
                </button>
                <button class="btn-history" data-location="hcm" aria-label="Tìm hiểu lịch sử TP.HCM">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Tìm Hiểu Lịch Sử
                </button>
            </div>
        </div>
    </section>

    <!-- 8. PHÚ QUỐC & CTA -->
    <section class="story-panel align-center" id="scene-8">
        <div class="glass-card text-center glass-card-sm">
            <div class="chapter">Chương Cuối / Biển Đảo</div>
            <h2>Phú Quốc<br><span>Đảo Ngọc Gọi Mời</span></h2>
            <p>Khép lại hành trình với tiếng sóng vỗ rì rào và bầu trời hoàng hôn rực lửa. Tận hưởng không gian bình yên và tái tạo năng lượng.</p>
            <div class="action-buttons justify-center">
                <button class="btn-play-video" data-target="vid-8" aria-label="Xem video về Phú Quốc">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg> Xem Video
                </button>
                <button class="btn-history" data-location="phuquoc" aria-label="Tìm hiểu lịch sử Phú Quốc">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Tìm Hiểu Lịch Sử
                </button>
            </div>
        </div>
    </section>

    <!-- HISTORY MODAL -->
    <div id="history-modal" class="history-modal hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <div class="modal-backdrop" aria-hidden="true"></div>
        <div class="modal-content glass-card">
            <button class="close-modal" aria-label="Đóng cửa sổ">&times;</button>
            <h3 id="modal-title"></h3>
            <div id="modal-body" class="modal-body"></div>
        </div>
    </div>

    <!-- SOLID BACKGROUND AREA (FOOTER) -->
    <div class="solid-wrapper" id="footer-area">
        @if (Model.RecentStories.Any())
        {
            <section class="stories-preview">
                <h2 class="stories-title">Câu Chuyện Từ Du Khách</h2>
                <div class="row g-4">
                    @foreach (var story in Model.RecentStories)
                    {
                        <div class="col-md-4">
                            <div class="glass-card story-card h-100 p-4">
                                <div class="small text-muted mb-2">@(story.Destination?.Name)</div>
                                <h5>@story.Title</h5>
                                <p class="story-excerpt">@(story.Content.Length > 100 ? story.Content.Substring(0, 100) + "..." : story.Content)</p>
                            </div>
                        </div>
                    }
                </div>
                <div class="text-center mt-4">
                    <a href="/Stories" class="btn-solid">Xem tất cả câu chuyện</a>
                </div>
            </section>
        }
        <footer class="premium-footer">
            <div class="footer-content">
                <div class="logo-icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                </div>
                <h2>Sẵn Sàng Khám Phá?</h2>
                <p>Hàng trăm điểm đến và vô vàn câu chuyện văn hóa đang chờ bạn.</p>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Hành Trình Việt Nam. Mọi quyền được bảo lưu.</p>
            </div>
        </footer>
    </div>
</main>

@section Scripts {
<script>
// --- SMOOTH SCROLL (LENIS) ---
const lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    direction: 'vertical',
    gestureDirection: 'vertical',
    smooth: true,
    mouseMultiplier: 1,
    touchMultiplier: 2,
});
function raf(time) {
    lenis.raf(time);
    requestAnimationFrame(raf);
}
requestAnimationFrame(raf);

// --- PRELOADER ---
document.addEventListener("DOMContentLoaded", () => {
    const preloader = document.getElementById("preloader");
    const progressBar = document.getElementById("progress-bar");
    
    let width = 0;
    const interval = setInterval(() => {
        width += 10;
        progressBar.style.width = width + "%";
        if (width >= 100) {
            clearInterval(interval);
            setTimeout(() => {
                preloader.classList.add("hidden");
                
                // Show first background image automatically
                const firstMedia = document.getElementById('vid-1');
                gsap.to(firstMedia, { opacity: 1, duration: 1.5, ease: "power2.inOut" });
            }, 500);
        }
    }, 50);
});

// --- GSAP & CLICK-TO-PLAY LOGIC ---
if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    // Sync Lenis with GSAP
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0, 0);

    // Navbar Scroll Effect
    const nav = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
    });

    // Hero Parallax Fade
    gsap.to(".hero-content", {
        scrollTrigger: {
            trigger: "#scene-1",
            start: "top top",
            end: "bottom top",
            scrub: true
        },
        opacity: 0,
        y: -100
    });

    // Glass Card Fade-up Animations
    const totalScenes = 8;
    for (let i = 2; i <= totalScenes; i++) {
        const card = document.querySelector(`#scene-${i} .glass-card`);
        if (card) {
            gsap.fromTo(card, 
                { y: 100, opacity: 0 },
                { 
                    scrollTrigger: {
                        trigger: `#scene-${i}`,
                        start: "top 80%",
                        end: "center center",
                        scrub: 1
                    },
                    y: 0, 
                    opacity: 1
                }
            );
        }
    }
    
    // Stop fixed video background from covering footer (Removed incorrect ScrollTrigger)

    // --- HISTORY MODAL LOGIC ---
    const historyData = {
        hanoi: {
            title: "Lịch Sử Hà Nội",
            content: "Được vua Lý Thái Tổ chọn làm kinh đô từ năm 1010 với tên gọi Thăng Long, Hà Nội tự hào trải qua hơn 1000 năm lịch sử hào hùng. Trải qua bao thăng trầm của các triều đại phong kiến, thời kỳ thuộc địa và những năm tháng kháng chiến, Hà Nội vẫn giữ vững vị thế là trái tim của cả nước, nơi hội tụ kết tinh tinh hoa văn hóa dân tộc."
        },
        halong: {
            title: "Lịch Sử Vịnh Hạ Long",
            content: "Nằm ở bờ Tây Vịnh Bắc Bộ, Vịnh Hạ Long được hình thành từ hàng triệu năm trước qua quá trình vận động địa chất phức tạp. Truyền thuyết kể rằng, Ngọc Hoàng sai rồng mẹ mang theo một đàn rồng con xuống hạ giới giúp người Việt đánh giặc ngoại xâm. Đàn rồng phun ra vô số châu ngọc, biến thành những đảo đá vôi, trở thành bức tường thành vững chắc cản bước quân thù."
        },
        hue: {
            title: "Lịch Sử Huế",
            content: "Phú Xuân (Huế) từng là thủ phủ của các chúa Nguyễn ở Đàng Trong, sau đó trở thành kinh đô của triều đại Tây Sơn, và cuối cùng là vương triều nhà Nguyễn (1802-1945). Mảnh đất cố đô mang trong mình những di sản kiến trúc đồ sộ, hệ thống lăng tẩm uy nghi và một nền văn hóa cung đình đặc sắc, được UNESCO công nhận là Di sản Văn hóa Thế giới."
        },
        hoian: {
            title: "Lịch Sử Hội An",
            content: "Ra đời vào khoảng thế kỷ 16-17, Hội An từng là một thương cảng quốc tế sầm uất bậc nhất Đông Nam Á, nơi giao thương của các thương nhân Nhật Bản, Trung Quốc và phương Tây. Dù trải qua nhiều biến cố lịch sử, Hội An may mắn giữ lại gần như nguyên vẹn quần thể kiến trúc phố cổ xưa, hòa quyện giữa các nền văn hóa đa dạng."
        },
        dalat: {
            title: "Lịch Sử Đà Lạt",
            content: "Được bác sĩ Alexandre Yersin khám phá vào năm 1893, Đà Lạt nhanh chóng được người Pháp xây dựng thành một trung tâm nghỉ dưỡng cao cấp tại Đông Dương. Trải qua hơn một thế kỷ, Đà Lạt vẫn giữ được vẻ đẹp lãng mạn của một \"Tiểu Paris\", với những dinh thự cổ kính ẩn mình giữa rừng thông và ngàn hoa khoe sắc."
        },
        hcm: {
            title: "Lịch Sử TP. Hồ Chí Minh",
            content: "Khởi đầu từ một vùng đất hoang vu, Sài Gòn nhanh chóng phát triển dưới thời các chúa Nguyễn và trở thành \"Hòn ngọc Viễn Đông\" sầm uất dưới thời Pháp thuộc. Ngày nay, TP.HCM là đầu tàu kinh tế của cả nước, biểu tượng của sự năng động, hiện đại và không ngừng vươn lên."
        },
        phuquoc: {
            title: "Lịch Sử Phú Quốc",
            content: "Được mệnh danh là \"Đảo Ngọc\", Phú Quốc từ lâu đã là vùng lãnh thổ thiêng liêng của tổ quốc. Trải qua những năm tháng lịch sử hào hùng, từ căn cứ chống Pháp của Nguyễn Trung Trực đến nhà tù Phú Quốc thời chiến, hòn đảo ngày nay đã chuyển mình trở thành một trung tâm du lịch nghỉ dưỡng đẳng cấp quốc tế."
        }
    };

    const historyModal = document.getElementById('history-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalBody = document.getElementById('modal-body');
    const closeBtn = document.querySelector('.close-modal');
    const backdrop = document.querySelector('.modal-backdrop');

    const sceneLinks = @Html.Raw(sceneLinksJson);

    function openModal(location) {
        if(historyData[location]) {
            modalTitle.textContent = historyData[location].title;
            let bodyHtml = `<p>${historyData[location].content}</p>`;
            if (sceneLinks[location] && sceneLinks[location].destinationId) {
                bodyHtml += `<a href="/Destinations/Details/${sceneLinks[location].destinationId}" class="btn-solid modal-cta-btn">Khám phá ${sceneLinks[location].destinationName}</a>`;
            } else {
                bodyHtml += `<a href="/Destinations" class="btn-solid modal-cta-btn">Khám phá điểm đến</a>`;
            }
            modalBody.innerHTML = bodyHtml;
            historyModal.classList.remove('hidden');
            if (typeof lenis !== 'undefined') lenis.stop();
        }
    }

    function closeModal() {
        historyModal.classList.add('hidden');
        if (typeof lenis !== 'undefined') lenis.start();
    }

    document.querySelectorAll('.btn-history').forEach(btn => {
        btn.addEventListener('click', function() {
            const loc = this.getAttribute('data-location');
            openModal(loc);
        });
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);

    // --- CLICK TO PLAY LOGIC ---
    const playButtons = document.querySelectorAll('.btn-play-video');
    playButtons.forEach(btn => {
        btn.addEventListener('click', function() {
            const targetId = this.getAttribute('data-target');
            
            // Toggle button states
            playButtons.forEach(b => b.classList.remove('playing'));
            this.classList.add('playing');

            // Handle videos and images
            for (let v = 1; v <= totalScenes; v++) {
                const media = document.getElementById(`vid-${v}`);
                if (`vid-${v}` === targetId) {
                    if (media.tagName.toLowerCase() === 'video') {
                        media.play().catch(e => console.log("Play failed:", e));
                    }
                    gsap.to(media, { opacity: 1, duration: 1.5, ease: "power2.inOut" });
                } else {
                    gsap.to(media, { opacity: 0, duration: 1.5, ease: "power2.inOut", onComplete: () => {
                        if (media.tagName.toLowerCase() === 'video') {
                            media.pause();
                            media.currentTime = 0; // optional reset
                        }
                    }});
                }
            }
        });
    });
}
</script>
}

<style>
