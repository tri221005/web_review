<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Việt Nam Hành Trình</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/page.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="premium-nav scrolled" id="navbar">
            <a href="/" class="nav-brand">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                <span>Việt Nam</span>
            </a>
            <button class="mobile-nav-toggle d-lg-none" id="mobileNavToggle" aria-label="Mở menu điều hướng">
                <i class="bi bi-list"></i>
            </button>
            <ul class="nav-links" id="navLinks">
                <li><a href="/Home/Index">Trang Chủ</a></li>
                <li><a href="/Destinations">Khám Phá</a></li>

                <li><a href="/Stories">Câu Chuyện</a></li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li><a href="/Destinations/Saved">Yêu Thích</a></li>
                    <li><a href="/Passport" class="nav-link-gold">Hộ Chiếu</a></li>
                    <li><a href="/Profile" class="nav-link-gold">Hồ Sơ</a></li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li><a href="/Admin/Dashboard" class="nav-link-admin">Admin</a></li>
                    }
                    <li>
                        <form class="form-inline m-0 nav-logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <button type="submit">Đăng Xuất</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a href="/Identity/Account/Login">Đăng Nhập</a></li>
                    <li><a href="/Identity/Account/Register" class="btn-nav-register">Đăng Ký</a></li>
                }
            </ul>
        </nav>
    </header>
    <style>
        .mobile-nav-toggle { display: none; }
        @@media (max-width: 991.98px) {
            .mobile-nav-toggle { display: block !important; }
            .nav-links { display: none; position: fixed; top: 70px; left: 0; width: 100%; flex-direction: column !important; background: rgba(10,10,15,0.98); backdrop-filter: blur(12px); padding: 1.5rem; gap: 1rem !important; border-bottom: 1px solid rgba(255,255,255,0.05); z-index: 1049; }
            .nav-links.show { display: flex !important; }
            .nav-links li { width: 100%; text-align: center; }
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toggle = document.getElementById('mobileNavToggle');
            var navLinks = document.getElementById('navLinks');
            if (toggle && navLinks) {
                toggle.addEventListener('click', function() {
                    navLinks.classList.toggle('show');
                    var icon = toggle.querySelector('i');
                    icon.classList.toggle('bi-list');
                    icon.classList.toggle('bi-x-lg');
                });
            }
        });
    </script>

    <main role="main" class="layout-main">
        @RenderBody()
    </main>
    @await Component.InvokeAsync("NToastNotify")

    <div class="solid-wrapper">
        <footer class="premium-footer">
            <div class="footer-content">
                <div class="logo-icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                </div>
                <h2>Sẵn Sàng Khám Phá?</h2>
                <p>Hàng trăm điểm đến và vô vàn câu chuyện văn hóa đang chờ bạn.</p>
            </div>
            <div class="footer-bottom-custom">
                <p>&copy; 2026 Hành Trình Việt Nam. Mọi quyền được bảo lưu.</p>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
