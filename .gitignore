```gitignore
# Build results
bin/
obj/
out/

# User-specific files
.vs/
*.user
*.userosscache
*.suo

# Environment specific settings
.env
.env.local
*.env.*

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Dependency directories
node_modules/
packages/

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Compiled files
*.dll
*.exe
*.pdb
*.nupkg
*.msi

# Testing
TestResults/

# Local configuration
appsettings.Development.json
appsettings.Production.json
```